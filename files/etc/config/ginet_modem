config modem 'settings'
	option enabled '1'
	option imei ''
	option apn 'internet'

config vpn 'sim1'
	option sim_slot '1'
	option sim_present '1'
	option vpn_enabled '0'
	option auto_update_wireguard '0'
	option always_on_vpn '0'
	option block_without_vpn '1'
	option active_tunnel ''

config vpn 'sim2'
	option sim_slot '2'
	option sim_present '0'
	option vpn_enabled '0'
	option auto_update_wireguard '0'
	option always_on_vpn '0'
	option block_without_vpn '1'
	option active_tunnel ''

config wireguard_tunnel
	option name 'default'
	option sim_slot '1'
	option enabled '0'
	option private_key ''
	option address ''
	option dns ''
	option public_key ''
	option preshared_key ''
	option endpoint_host ''
	option endpoint_port '51820'
	option allowed_ips '0.0.0.0/0,::/0'
	option persistent_keepalive '25'
	option mtu '1420'
	option obfuscation '0'
	option obfs_type 'udp2raw'
	option obfs_params ''

# Stealth / privacy controls. These reduce common passive fingerprinting
# vectors. They do NOT guarantee that a carrier or observer cannot identify
# tethering, the device, or its location.
config stealth 'settings'
	# TTL/hop-limit normalization: rewrite outbound TTL to a fixed value so all
	# traffic appears to originate from a single device (common tethering check).
	option ttl_normalize '0'
	option ttl_value '65'
	# Pin a WAN MTU to blend traffic profiles (0 = leave unchanged).
	option wan_mtu '0'
	# Tethering-hiding bundle convenience flag (enables TTL + MTU guidance).
	option hide_tethering '0'

# Per-interface MAC randomization policy.
#   mode: off | on-boot | on-reconnect | scheduled
#   interval_minutes: used only when mode = scheduled
config macrand 'ap'
	option ifname 'wlan0'
	option mode 'off'
	option interval_minutes '60'

config macrand 'sta'
	option ifname ''
	option mode 'off'
	option interval_minutes '15'

# Cell watch: rogue-tower heuristics + coarse tower-based location.
config cellwatch 'settings'
	option enabled '0'
	# Poll interval in minutes for the monitor cron job.
	option interval_minutes '5'
	# Raise an alert when the network is forced down to 2G/3G.
	option alert_downgrade '1'
	# Raise an alert on unexpected serving Cell ID / LAC changes.
	option alert_cellid_change '1'
	# Coarse location lookup from cell identifiers. Uses a LOCAL offline
	# database only (never queries the network) to avoid leaking cell IDs.
	option location_enabled '0'
	option location_db '/etc/ginet/cell_db.csv'

# Performance controls. These speed up the internet path WITHOUT weakening any
# of the security/hardening controls above. All options default to off/safe so
# existing behavior is unchanged until a user opts in.
#   mss_clamp:            clamp TCP MSS to the path MTU (fixes cellular+WireGuard
#                         fragmentation/black-holing that tanks throughput).
#   sqm_enabled/sqm_qdisc: apply a bufferbloat-fighting queueing discipline
#                         (fq_codel by default) on the WAN device.
#   flow_offloading:      software flow offload for higher NAT throughput. It is
#                         FAIL-CLOSED: it self-disables whenever a kill-switch is
#                         configured or TTL normalization is on, because those
#                         rely on seeing every packet.
#   flow_offloading_hw:   additionally request hardware offload (only honored
#                         when software offload is active and safe).
config perf 'settings'
	option mss_clamp '0'
	option sqm_enabled '0'
	option sqm_qdisc 'fq_codel'
	option flow_offloading '0'
	option flow_offloading_hw '0'

# link degrades past a sustained threshold, with hysteresis and cooldown so it
# does not flap.
config vpn_watchdog 'settings'
	option enabled '0'
	option interval_minutes '2'
	# Host to probe for reachability/latency (through the tunnel).
	option probe_host '1.1.1.1'
	# Latency ceiling in milliseconds before a sample counts as "bad".
	option max_latency_ms '800'
	# Consecutive bad samples required before acting (hysteresis).
	option fail_threshold '3'
	# Minimum seconds between corrective actions (cooldown).
	option cooldown_seconds '300'
	# Try the next configured tunnel for the SIM on repeated failure (failover).
	option failover '0'
