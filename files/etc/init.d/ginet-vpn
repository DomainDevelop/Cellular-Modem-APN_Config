#!/bin/sh /etc/rc.common

START=18
STOP=89
USE_PROCD=1

start_service() {
	procd_open_instance
	procd_set_param command /usr/bin/ginet-vpn-policy.sh boot
	procd_set_param respawn 3600 5 -1
	procd_close_instance

	mkdir -p /etc/crontabs
	touch /etc/crontabs/root
	if [ -f /etc/crontabs/root ]; then
		sed -i '/ginet-wg-update-check\.sh/d' /etc/crontabs/root
	fi
	if ! grep -qF '0 3 * * * /usr/bin/ginet-wg-update-check.sh' /etc/crontabs/root 2>/dev/null; then
		echo '0 3 * * * /usr/bin/ginet-wg-update-check.sh' >> /etc/crontabs/root
	fi
	/etc/init.d/cron restart >/dev/null 2>&1 || true
}

stop_service() {
	/usr/bin/ginet-vpn-policy.sh apply >/dev/null 2>&1 || true
}

reload_service() {
	/usr/bin/ginet-vpn-policy.sh apply >/dev/null 2>&1 || true
}
