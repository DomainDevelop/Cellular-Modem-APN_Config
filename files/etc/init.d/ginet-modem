#!/bin/sh /etc/rc.common
# GiNet Modem Status Monitor Init Script
# Maintains real-time modem status for LuCI interface

START=99
STOP=01
USE_PROCD=1

MODEM_SCRIPT="/usr/bin/ginet-modem-status.sh"
STATUS_FILE="/tmp/ginet_modem_status.json"
PID_FILE="/var/run/ginet-modem.pid"

service_triggers() {
	procd_add_reload_trigger "ginet_modem"
}

start_service() {
	procd_open_instance "ginet-modem"
	procd_set_param command /bin/sh "$MODEM_SCRIPT"
	procd_set_param respawn 3600 5 -1
	procd_set_param pidfile "$PID_FILE"
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
	
	# Initial status update
	$MODEM_SCRIPT > "$STATUS_FILE" 2>/dev/null
	
	uci -q get ginet_modem.settings.enabled >/dev/null || uci set ginet_modem.settings.enabled='1'
	uci commit ginet_modem
}

stop_service() {
	[ -f "$PID_FILE" ] && kill $(cat "$PID_FILE") 2>/dev/null
	rm -f "$PID_FILE"
}

reload_service() {
	stop_service
	start_service
}

service_started() {
	uci -q get ginet_modem.settings.enabled >/dev/null 2>&1 && {
		echo "GiNet Modem Status Monitor started"
	}
}
