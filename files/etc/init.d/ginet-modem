#!/bin/sh /etc/rc.common

START=60
STOP=20
USE_PROCD=1

MODEM_SCRIPT="/usr/bin/ginet-modem-status.sh"
STATUS_FILE="/tmp/ginet_modem_status.json"

service_triggers() {
	procd_add_reload_trigger "ginet_modem"
}

start_service() {
	procd_open_instance "ginet-modem"
	procd_set_param command "$MODEM_SCRIPT" daemon
	procd_set_param respawn 3600 5 -1
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance

	"$MODEM_SCRIPT" > "$STATUS_FILE" 2>/dev/null || true
}

reload_service() {
	"$MODEM_SCRIPT" > "$STATUS_FILE" 2>/dev/null || true
}
